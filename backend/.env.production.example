# SwasthyaSaathi Lite - Backend Production Environment Variables

# Server
PORT=5000
NODE_ENV=production

# Security
# The URL of your deployed Vercel frontend (e.g., https://swasthya-saathi.vercel.app)
FRONTEND_URL=your-vercel-frontend-url

# AI Services
GROQ_API_KEY=your-groq-api-key

# Messaging Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Database (if applicable)
DB_URL=your-database-url
